# App
NODE_ENV=development
API_PORT=3333
# URL pública da API. É usada no pixel de rastreamento de abertura dos e-mails de NFS-e.
# Para o "log de visualização" funcionar, precisa ser um endereço ALCANÇÁVEL pelo
# cliente de e-mail do destinatário (ex.: domínio público HTTPS, ou um túnel como
# ngrok em dev). Com http://localhost:3333 o Gmail/Outlook não consegue carregar o
# pixel e nenhuma visualização é registrada.
API_PUBLIC_URL=http://localhost:3333
WEB_PORT=3000
WEB_ORIGIN=http://localhost:3000
# URL da API consumida pelo frontend (Next.js). Em produção use HTTPS para que e-mail/senha
# nunca trafeguem em texto claro. Precisa do prefixo NEXT_PUBLIC_ para ir ao navegador.
NEXT_PUBLIC_API_URL=http://localhost:3333
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=change-me-in-development
WEB_PUBLIC_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://nfse:nfse@127.0.0.1:5432/nfse?schema=public"

# Storage
STORAGE_DRIVER=local
STORAGE_PATH=./storage

# Certificate encryption
CERTIFICATE_ENCRYPTION_KEY=change-me-32-bytes-minimum

# Secrets for encrypted company SMTP passwords
SMTP_SETTINGS_SECRET=change-me-32-bytes-minimum

# NFS-e Nacional
NFSE_ENV=restricted-production
NFSE_BASE_URL=https://adn.producaorestrita.nfse.gov.br

# SMTP do sistema para convites e recuperação de senha.
# IMPORTANTE: use uma caixa de envio DEDICADA (ex.: nao-responda@seudominio)
# que NÃO seja o e-mail (nem um alias) de nenhum usuário do portal.
# Se o remetente (SMTP_USER/SMTP_FROM) coincidir com a caixa de um usuário,
# o Gmail/Workspace trata a mensagem como "enviada para si mesmo" e a esconde
# da Caixa de entrada desse usuário (ela só aparece em "Enviados"). Foi o que
# acontecia com o admin, cujo e-mail era um alias da conta remetente.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=nao-responda@zipcontabilidade.com.br
SMTP_FROM_NAME=ZIP Contabilidade
PASSWORD_RESET_EXPIRES_MINUTES=60

# Acessorias
ACESSORIAS_API_BASE_URL=https://api.acessorias.com
ACESSORIAS_API_TOKEN=change-me
ACESSORIAS_ATTACHMENT_FIELD=arquivo[]
ACESSORIAS_FILE_ALLOWED_HOSTS=acessorias.com

# Indicadores (e-Kontroll). POST {BASE}/{metodo}, parâmetros www-form-urlencoded.
# Chaves obtidas em Integrações > e-API > Ativação API no e-Kontroll:
#  - EKONTROLL_API_KEY: campo "API Key" do escritório (chave do aplicativo).
#  - EKONTROLL_API_KEY_EMPRESA: campo "API Key das empresas" (usada no método listar_empresas).
#  - A chave de cada empresa (api_key_cliente) é cadastrada por empresa em Configurações > Controle.
EKONTROLL_API_BASE_URL=https://app.e-kontroll.com.br/api/v1/metodo
EKONTROLL_API_KEY=change-me
EKONTROLL_API_KEY_EMPRESA=
EKONTROLL_API_KEY_CLIENTE=
# Métodos por departamento (Contabilidade/Fiscal/Pessoal). Métodos de departamento
# exigem parâmetros de período (competência). Ex.: balancete, impostos, resumo.
EKONTROLL_METHOD_ACCOUNTING=balancete
EKONTROLL_METHOD_TAX=impostos
EKONTROLL_METHOD_PAYROLL=resumo
