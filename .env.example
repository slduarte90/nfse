# App
NODE_ENV=development
API_PORT=3333
API_PUBLIC_URL=http://localhost:3333
WEB_PORT=3000
WEB_ORIGIN=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=change-me-in-development
WEB_PUBLIC_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://nfse:nfse@127.0.0.1:5432/nfse?schema=public"

# Storage
STORAGE_DRIVER=local
STORAGE_PATH=./storage

# Certificate encryption
CERTIFICATE_ENCRYPTION_KEY=change-me-32-bytes-minimum

# Secrets for encrypted company SMTP passwords
SMTP_SETTINGS_SECRET=change-me-32-bytes-minimum

# NFS-e Nacional
NFSE_ENV=restricted-production
NFSE_BASE_URL=https://adn.producaorestrita.nfse.gov.br

# SMTP do sistema para convites e recuperação de senha.
# IMPORTANTE: use uma caixa de envio DEDICADA (ex.: nao-responda@seudominio)
# que NÃO seja o e-mail (nem um alias) de nenhum usuário do portal.
# Se o remetente (SMTP_USER/SMTP_FROM) coincidir com a caixa de um usuário,
# o Gmail/Workspace trata a mensagem como "enviada para si mesmo" e a esconde
# da Caixa de entrada desse usuário (ela só aparece em "Enviados"). Foi o que
# acontecia com o admin, cujo e-mail era um alias da conta remetente.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=nao-responda@zipcontabilidade.com.br
SMTP_FROM_NAME=ZIP Contabilidade
PASSWORD_RESET_EXPIRES_MINUTES=60

# Acessorias
ACESSORIAS_API_BASE_URL=https://api.acessorias.com
ACESSORIAS_API_TOKEN=change-me
ACESSORIAS_ATTACHMENT_FIELD=arquivo[]
ACESSORIAS_FILE_ALLOWED_HOSTS=acessorias.com

# E-Kontroll
EKONTROLL_API_BASE_URL=https://app.e-kontroll.com.br/api/v1/metodo
EKONTROLL_API_KEY=change-me
EKONTROLL_API_KEY_EMPRESA=
EKONTROLL_API_KEY_CLIENTE=
EKONTROLL_METHOD_ACCOUNTING=
EKONTROLL_METHOD_TAX=
EKONTROLL_METHOD_PAYROLL=
