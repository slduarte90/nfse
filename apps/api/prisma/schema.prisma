generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountRole {
  ADMIN
  USER
}

enum UserRole {
  OWNER
  ADMIN
  OPERATOR
  VIEWER
}

enum CompanyUserStatus {
  ACTIVE
  BLOCKED
  DISABLED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum CertificateStatus {
  PENDING
  VALID
  EXPIRED
  INVALID
  REVOKED
}

enum InvoiceStatus {
  DRAFT
  PROCESSING
  AUTHORIZED
  REJECTED
  CANCELLED
}

enum StorageKind {
  XML
  PDF
  CERTIFICATE
}

enum NfseRecurrenceFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum NfseRecurrenceStatus {
  ACTIVE
  PAUSED
  FINISHED
}

enum MailStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum NfseEnvironment {
  PRODUCTION_RESTRICTED
  PRODUCTION
}

enum NfseTaxRegime {
  NONE
  MEI
  SIMPLE_NATIONAL
  NORMAL
  SPECIAL
}

model User {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  passwordHash String
  accountRole  AccountRole @default(USER)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  companies       CompanyUser[]
  auditLogs       AuditLog[]
  sentInvitations UserInvitation[] @relation("InvitationSender")
}

model Company {
  id                    String   @id @default(uuid())
  legalName             String
  tradeName             String?
  cnpj                  String   @unique
  municipalRegistration String?
  city                  String
  state                 String
  country               String?  @default("Brasil")
  zipCode               String?
  address               String?
  number                String?
  complement            String?
  neighborhood          String?
  email                 String?
  phone                 String?
  registrationStatus    String?
  mainActivity          String?
  legalNature           String?
  taxRegime             String
  serviceCodeDefault    String?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  users        CompanyUser[]
  certificates DigitalCertificate[]
  customers    Customer[]
  invoices     NfseInvoice[]
  services     NfseService[]
  recurrences  NfseRecurrence[]
  nfseSettings NfseSettings?
  accountingRecords AccountingRecord[]
  accountingSyncs    AccountingSync[]
  auditLogs    AuditLog[]
  invitations  UserInvitation[]
}

model CompanyUser {
  id        String            @id @default(uuid())
  userId    String
  companyId String
  role      UserRole          @default(OPERATOR)
  permissions Json?
  status    CompanyUserStatus @default(ACTIVE)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @default(now()) @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
}

model UserInvitation {
  id          String           @id @default(uuid())
  companyId   String
  invitedById String
  name        String?
  email       String
  role        UserRole         @default(OPERATOR)
  permissions Json?
  token       String           @unique
  groupToken  String?
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  company   Company @relation(fields: [companyId], references: [id])
  invitedBy User    @relation("InvitationSender", fields: [invitedById], references: [id])

  @@index([companyId, email])
  @@index([groupToken])
}

model DigitalCertificate {
  id                 String            @id @default(uuid())
  companyId          String
  originalFileName   String
  encryptedPath      String
  encryptedPassword  String?
  subjectName        String?
  issuerName         String?
  serialNumber       String?
  validFrom          DateTime?
  validUntil         DateTime?
  status             CertificateStatus @default(PENDING)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

model NfseSettings {
  id                       String          @id @default(uuid())
  companyId                String          @unique
  environment              NfseEnvironment @default(PRODUCTION_RESTRICTED)
  apiBaseUrl               String?
  apiVersion               String?
  municipalIbgeCode        String?
  municipalRegistration    String?
  taxRegime                NfseTaxRegime   @default(NORMAL)
  specialTaxRegime         String?
  isSimpleNational         Boolean         @default(false)
  hasFiscalIncentive       Boolean         @default(false)
  defaultIssWithheld       Boolean         @default(false)
  defaultOperationNature   String?
  defaultRpsSeries         String?
  certificateId            String?
  lastCertificateValidated DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, environment])
}

model NfseService {
  id                   String   @id @default(uuid())
  companyId            String
  name                 String
  description          String?
  cnae                 String?
  nbsCode              String?
  ibsCbsTaxClassCode   String?
  ibsCbsOperationCode  String?
  nationalTaxCode      String
  municipalServiceCode String?
  cityServiceCode      String?
  issRate              Decimal? @db.Decimal(5, 2)
  isIssWithheld        Boolean  @default(false)
  isDefault            Boolean  @default(false)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company  Company       @relation(fields: [companyId], references: [id])
  invoices NfseInvoice[]
  recurrences NfseRecurrence[]

  @@index([companyId, isActive])
  @@index([companyId, cnae])
}

model Customer {
  id                    String   @id @default(uuid())
  companyId             String
  name                  String
  document              String
  email                 String?
  phone                 String?
  municipalRegistration String?
  stateRegistration     String?
  city                  String?
  state                 String?
  country               String?  @default("Brasil")
  zipCode               String?
  address               String?
  number                String?
  complement            String?
  neighborhood          String?
  foreignDocument       String?
  isForeign             Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  company  Company       @relation(fields: [companyId], references: [id])
  invoices NfseInvoice[]
  recurrences NfseRecurrence[]

  @@index([companyId, isActive])
  @@index([companyId, document])
  @@index([companyId, name])
}

model NfseInvoice {
  id                    String        @id @default(uuid())
  companyId             String
  customerId            String?
  serviceId             String?
  status                InvoiceStatus @default(DRAFT)
  number                String?
  series                String?
  rpsNumber             String?
  rpsSeries             String?
  dpsId                 String?
  accessKey             String?
  verificationCode      String?
  amount                Decimal       @db.Decimal(12, 2)
  deductions            Decimal?      @db.Decimal(12, 2)
  discounts             Decimal?      @db.Decimal(12, 2)
  issRate               Decimal?      @db.Decimal(5, 2)
  issAmount             Decimal?      @db.Decimal(12, 2)
  issWithheld           Boolean       @default(false)
  serviceDescription    String
  serviceCode           String?
  nationalTaxCode       String?
  municipalServiceCode  String?
  municipalIbgeCode     String?
  competenceDate        DateTime?
  operationNature       String?
  additionalInformation String?
  xmlPath               String?
  pdfPath               String?
  requestPayload        Json?
  responsePayload       Json?
  errorCode             String?
  errorMessage          String?
  createdByUserId       String?
  createdByName         String?
  updatedByUserId       String?
  updatedByName         String?
  transmittedByUserId   String?
  transmittedByName     String?
  issuedAt              DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  company  Company       @relation(fields: [companyId], references: [id])
  customer Customer?     @relation(fields: [customerId], references: [id])
  service  NfseService?  @relation(fields: [serviceId], references: [id])
  events   NfseEvent[]
  files    StoredFile[]
  mailLogs NfseMailLog[]

  @@index([companyId, status])
  @@index([companyId, number])
  @@index([companyId, accessKey])
  @@index([customerId])
}

model NfseEvent {
  id          String   @id @default(uuid())
  invoiceId   String
  type        String
  description String?
  payload     Json?
  createdAt   DateTime @default(now())

  invoice NfseInvoice @relation(fields: [invoiceId], references: [id])
}

model StoredFile {
  id        String      @id @default(uuid())
  invoiceId String?
  kind      StorageKind
  path      String
  fileName  String
  mimeType  String
  sizeBytes Int?
  createdAt DateTime    @default(now())

  invoice NfseInvoice? @relation(fields: [invoiceId], references: [id])
}

model NfseRecurrence {
  id                    String                  @id @default(uuid())
  companyId             String
  customerId            String
  serviceId             String?
  frequency             NfseRecurrenceFrequency @default(MONTHLY)
  interval              Int                     @default(1)
  startDate             DateTime
  nextRunAt             DateTime
  endDate               DateTime?
  status                NfseRecurrenceStatus    @default(ACTIVE)
  amount                Decimal                 @db.Decimal(12, 2)
  issRate               Decimal?                @db.Decimal(5, 2)
  issWithheld           Boolean                 @default(false)
  serviceDescription    String
  nationalTaxCode       String?
  municipalServiceCode  String?
  municipalIbgeCode     String?
  additionalInformation String?
  lastInvoiceId         String?
  lastRunAt             DateTime?
  createdByUserId       String?
  createdByName         String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  company  Company      @relation(fields: [companyId], references: [id])
  customer Customer     @relation(fields: [customerId], references: [id])
  service  NfseService? @relation(fields: [serviceId], references: [id])

  @@index([companyId, status])
  @@index([nextRunAt, status])
}

model NfseMailLog {
  id           String     @id @default(uuid())
  invoiceId    String
  recipient    String
  subject      String
  status       MailStatus @default(PENDING)
  errorMessage String?
  sentAt       DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  invoice NfseInvoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([status])
}

model AccountingRecord {
  id                String   @id @default(uuid())
  companyId         String
  provider          String   @default("ACESSORIAS")
  area              String
  externalId        String
  title             String
  description       String?
  status            String?
  department        String?
  dueDate           DateTime?
  sentAt            DateTime?
  openedAt          DateTime?
  updatedExternalAt DateTime?
  payload           Json?
  normalized        Json?
  syncedAt          DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  files   AccountingFile[]

  @@unique([companyId, provider, area, externalId])
  @@index([companyId, area, status])
  @@index([companyId, area, dueDate])
}

model AccountingFile {
  id           String   @id @default(uuid())
  recordId     String?
  companyId    String?
  provider     String   @default("ACESSORIAS")
  area         String?
  direction    String   @default("INBOUND")
  externalId   String?
  fileName     String
  mimeType     String
  path         String
  sourceUrl    String?
  sizeBytes    Int?
  downloadedAt DateTime @default(now())
  createdAt    DateTime @default(now())

  record AccountingRecord? @relation(fields: [recordId], references: [id])

  @@index([recordId])
  @@index([companyId, area])
  @@index([companyId, provider, externalId])
}

model AccountingSync {
  id              String   @id @default(uuid())
  companyId       String
  provider        String   @default("ACESSORIAS")
  area            String
  lastSyncedAt    DateTime?
  lastResultCount Int      @default(0)
  lastError       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, provider, area])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  companyId String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])
}
